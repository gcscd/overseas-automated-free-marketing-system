# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./data/hermes.db

# Server Configuration
HOST=0.0.0.0
PORT=8080
DEBUG=False

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Hermes Agent Configuration
HERMES_AGENT_CONFIG=config/agent.yaml
AGENT_MAX_CONCURRENT_TASKS=10
AGENT_DEFAULT_MAX_RETRY=2

# AI Model Configuration
DEFAULT_AI_MODEL=claude-3-5-sonnet
AI_API_BASE_URL=https://api.anthropic.com
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# Security
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/hermes.log
